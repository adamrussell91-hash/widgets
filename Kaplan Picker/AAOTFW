          "Find a moment in the extract where this is most visible.",
          "Explain why the paradox makes this an unusually powerful form of first-person narration.",
          "Write a sentence naming the paradox as a structural principle of the novel."
        ]
      },
      open: {
        main: "The paradox of the unreliable narrator is that the more convincingly he lies, the more convincingly the truth is exposed. Make a sustained argument about how Ishiguro exploits this paradox.",
        steps: []
      },
      essay: {
        main: "Write a paragraph arguing that the paradox at the centre of unreliable narration — that every attempt at concealment is simultaneously a form of revelation — is Ishiguro's most important technical achievement.",
        steps: []
      }
    },
    projection: {
      scaffold: {
        main: "Ono accuses others of the very traits he embodies — yet in doing so, he reveals exactly what he is trying to hide. What is the paradox here — and why is it not simply ironic?",
        steps: [
          "Name the paradox: projection simultaneously conceals and reveals.",
          "Explain why 'paradox' is more precise than 'irony' in this context.",
          "Find evidence in the extract of both movements — concealment and revelation — occurring at once.",
          "Write a sentence holding the paradox in tension without resolving it."
        ]
      },
      open: {
        main: "The paradox of Ono's projection is that it achieves exactly the opposite of its purpose: by attributing his failings to others, he makes them more visible. Make an argument about how Ishiguro exploits this paradox.",
        steps: []
      },
      essay: {
        main: "Write a paragraph arguing that the central paradox of Ono's projection — that it simultaneously conceals and exposes — is the primary mechanism by which Ishiguro constructs his critique of post-war denial.",
        steps: []
      }
    }
  }
};

// Fallback generator for combinations not explicitly defined
function generateFallback(element, topic, level) {
  const meta = elementMeta[element];
  const topicLabels = {
    hypocrisy: "Ono's hypocrisy and self-blindness",
    superiority: "Ono's need to assert superiority",
    shintaro: "the critique of Shintaro",
    setting: "the bar setting and change",
    nostalgia: "nostalgia and the past",
    propaganda: "propaganda and war responsibility",
    irony: "the unreliable narrator and irony",
    projection: "Ono's projection onto others"
  };
  const topicLabel = topicLabels[topic] || topic;

  const templates = {
    scaffold: {
      main: `Apply the concept of <em>${meta.label.toLowerCase()}</em> to ${topicLabel} in this extract. What does this lens reveal that a surface reading would miss?`,
      steps: [
        `Define what ${meta.label.toLowerCase()} means in the context of literary analysis.`,
        `Identify a specific moment in the extract that this concept illuminates.`,
        `Explain what the concept reveals about Ono's character or Ishiguro's purpose.`,
        `Connect your reading to the broader themes of post-war Japan.`
      ]
    },
    open: {
      main: `Using the lens of <em>${meta.label.toLowerCase()}</em>, construct a sophisticated argument about ${topicLabel} in the extract. What does this lens make visible that others cannot?`,
      steps: []
    },
    essay: {
      main: `Write a structured analytical paragraph using <em>${meta.label.toLowerCase()}</em> as your central lens to examine ${topicLabel}. Ensure your opening sentence is debatable.`,
      steps: [
        "Debatable topic sentence naming the key idea.",
        "Embedded quotation with precise word-level analysis.",
        "Link to Ishiguro's historical or cultural context."
      ]
    }
  };

  return templates[level] || templates.scaffold;
}

function getPromptContent(element, topic, level) {
  if (promptData[element] && promptData[element][topic] && promptData[element][topic][level]) {
    return promptData[element][topic][level];
  }
  return generateFallback(element, topic, level);
}

function buildCard(element, topic, level) {
  const meta = elementMeta[element];
  const content = getPromptContent(element, topic, level);
  const topicLabels = {
    hypocrisy: "Hypocrisy & Blindness",
    superiority: "Need for Superiority",
    shintaro: "Critique of Shintaro",
    setting: "Setting & Change",
    nostalgia: "Nostalgia & the Past",
    propaganda: "Propaganda & War",
    irony: "Unreliable Narrator",
    projection: "Projection"
  };

  const scaffoldHtml = content.steps && content.steps.length > 0
    ? `<div class="prompt-scaffolds">
        ${content.steps.map((s, i) => `
          <div class="scaffold-item">
            <span class="scaffold-num">0${i+1}</span>
            <span class="scaffold-text">${s}</span>
          </div>`).join('')}
       </div>`
    : '';

  return `
    <div class="prompt-card">
      <div class="card-header">
        <span class="element-badge ${meta.css}">${meta.label}</span>
        <span class="card-section-label">${topicLabels[topic] || topic}</span>
      </div>
      <div class="card-body">
        <div class="main-prompt">${content.main}</div>
        ${scaffoldHtml}
      </div>
      <div class="card-footer">
        <span class="tip"><strong>Tip:</strong> ${meta.tip}</span>
        <button class="copy-btn" onclick="copyPrompt(this)">Copy</button>
      </div>
    </div>`;
}

function buildSetOfThree(topic, level) {
  // Pick 3 elements that make sense together
  const sets = {
    hypocrisy: ['language', 'patterns', 'ethics'],
    shintaro: ['perspectives', 'paradox', 'patterns'],
    setting: ['language', 'change', 'perspectives'],
    nostalgia: ['patterns', 'paradox', 'ethics'],
    propaganda: ['ethics', 'perspectives', 'origins'],
    superiority: ['patterns', 'paradox', 'perspectives'],
    irony: ['language', 'paradox', 'perspectives'],
    projection: ['paradox', 'patterns', 'ethics']
  };
  const elements = sets[topic] || ['language', 'patterns', 'ethics'];
  return `<div class="multi-grid">${elements.map(el => buildCard(el, topic, level)).join('')}</div>`;
}

async function generatePrompts() {
  const element = document.getElementById('elementSelect').value;
  const topic = document.getElementById('topicSelect').value;
  const level = document.getElementById('levelSelect').value;
  const mode = document.getElementById('modeSelect').value;
  
  const btn = document.querySelector('.generate-btn');
  const spinner = document.getElementById('spinner');
  const btnText = document.getElementById('btnText');
  const output = document.getElementById('output');

  btn.disabled = true;
  spinner.style.display = 'block';
  btnText.textContent = 'Generating…';
  output.innerHTML = `<div class="loading-state"><div class="loading-spinner"></div>Composing your prompt…</div>`;

  await new Promise(r => setTimeout(r, 600));

  try {
    let html;
    if (mode === 'set') {
      html = buildSetOfThree(topic, level);
    } else {
      html = buildCard(element, topic, level);
    }
    output.innerHTML = html;
  } catch(e) {
    output.innerHTML = `<div class="error-card">Something went wrong generating the prompt. Please try again.</div>`;
  }

  btn.disabled = false;
  spinner.style.display = 'none';
  btnText.textContent = 'Generate Prompt';
}

function copyPrompt(btn) {
  const card = btn.closest('.prompt-card');
  const main = card.querySelector('.main-prompt').innerText;
  const steps = [...card.querySelectorAll('.scaffold-text')].map((s, i) => `${i+1}. ${s.innerText}`).join('\n');
  const tip = card.querySelector('.tip').innerText;
  const text = steps ? `${main}\n\nSteps:\n${steps}\n\n${tip}` : `${main}\n\n${tip}`;
  navigator.clipboard.writeText(text).then(() => {
    btn.textContent = 'Copied!';
    setTimeout(() => btn.textContent = 'Copy', 1500);
  });
}
